#!/bin/bash
# ═══════════════════════════════════════════════════════
# Saral Language Installer — Linux Mint / Ubuntu / Debian
# Version 1.0.0 "First Public Release"
# Run with: bash install_linux.sh
# Developer: Asha V S, Kerala, India
# ═══════════════════════════════════════════════════════

set -e

SARAL_VERSION="1.0.0"
SARAL_DIR="$HOME/.saral"
SARAL_BIN="/usr/local/bin/saral"

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m'

print_step()  { echo -e "\n${BLUE}▶  $1${NC}"; }
print_ok()    { echo -e "   ${GREEN}✅  $1${NC}"; }
print_warn()  { echo -e "   ${YELLOW}⚠️   $1${NC}"; }
print_error() { echo -e "   ${RED}❌  $1${NC}"; }

echo ""
echo "╔══════════════════════════════════════════════╗"
echo "║   🌿  SARAL LANG v$SARAL_VERSION Installer          ║"
echo "║   Simple programming for everyone            ║"
echo "║   Developed by Asha V S, Kerala, India       ║"
echo "╚══════════════════════════════════════════════╝"
echo ""

# ── Step 1: Check Python ──────────────────────────────
print_step "Checking Python..."
if command -v python3 &>/dev/null; then
    PY_VER=$(python3 --version 2>&1 | awk '{print $2}')
    print_ok "Python $PY_VER found"
    PYTHON=python3
else
    print_warn "Python 3 not found. Installing..."
    sudo apt-get update -qq
    sudo apt-get install -y python3 python3-pip
    PYTHON=python3
    print_ok "Python 3 installed"
fi

# ── Step 2: Create Saral directory ───────────────────
print_step "Setting up Saral directory at $SARAL_DIR..."
mkdir -p "$SARAL_DIR"
mkdir -p "$SARAL_DIR/examples"
mkdir -p "$SARAL_DIR/stdlib"
print_ok "Directory created"

# ── Step 3: Copy Saral core files ────────────────────
print_step "Installing Saral core files..."

# Detect source directory
# Supports running from: saral-lang/ root OR saral-lang/core/
if [ -f "core/saral.py" ]; then
    SRC_DIR="core"
    print_ok "Detected project root — using core/ subfolder"
elif [ -f "saral.py" ]; then
    SRC_DIR="."
    print_ok "Detected core folder — using current directory"
else
    print_error "Cannot find saral.py"
    print_error "Please run this installer from the saral-lang/ folder"
    exit 1
fi

# ── Core compiler pipeline files ─────────────────────
# These are the exact files in Saral Lang v1.0.0
CORE_FILES=(
    saral.py
    pipeline.py
    lexer.py
    parser.py
    ast_nodes.py
    codegen.py
    analyzer.py
    sourcemap.py
    errors.py
    ai_helper.py
    __init__.py
)

for f in "${CORE_FILES[@]}"; do
    if [ -f "$SRC_DIR/$f" ]; then
        cp "$SRC_DIR/$f" "$SARAL_DIR/"
        print_ok "Copied $f"
    else
        print_error "Missing: $f — check your saral-lang folder is complete"
        exit 1
    fi
done

# ── Optional: ai_config.py (AI provider configuration) ─
if [ -f "$SRC_DIR/ai_config.py" ]; then
    cp "$SRC_DIR/ai_config.py" "$SARAL_DIR/"
    print_ok "Copied ai_config.py"
else
    print_warn "ai_config.py not found — AI setup wizard unavailable"
    print_warn "Run 'saral --setup-ai' after adding ai_config.py"
fi

# ── Copy example programs ─────────────────────────────
EXAMPLES_DIR="examples"
if [ ! -d "$EXAMPLES_DIR" ] && [ -d "$SRC_DIR/../examples" ]; then
    EXAMPLES_DIR="$SRC_DIR/../examples"
fi
if [ -d "$EXAMPLES_DIR" ]; then
    cp "$EXAMPLES_DIR"/*.saral "$SARAL_DIR/examples/" 2>/dev/null || true
    print_ok "Copied example programs"
else
    print_warn "No examples folder found — skipping examples"
fi

print_ok "All Saral files installed"

# ── Step 4: Create saral command ─────────────────────
print_step "Creating 'saral' command..."
sudo tee "$SARAL_BIN" > /dev/null << CMDEOF
#!/bin/bash
$PYTHON $SARAL_DIR/saral.py "\$@"
CMDEOF
sudo chmod +x "$SARAL_BIN"
print_ok "'saral' command created"
print_ok "You can now type: saral myfile.saral"

# ── Step 5: Create desktop shortcut ──────────────────
print_step "Creating desktop shortcut..."
DESKTOP_FILE="$HOME/Desktop/Saral.desktop"
if [ -d "$HOME/Desktop" ]; then
    cat > "$DESKTOP_FILE" << DESKEOF
[Desktop Entry]
Version=1.0
Type=Application
Name=Saral Interactive
Comment=Saral Lang — Simple Programming for Everyone
Exec=bash -c '$PYTHON $SARAL_DIR/saral.py --interactive; read'
Icon=utilities-terminal
Terminal=true
Categories=Development;
DESKEOF
    chmod +x "$DESKTOP_FILE"
    print_ok "Desktop shortcut created"
else
    print_warn "Desktop folder not found — skipping shortcut"
fi

# ── Step 6: Add to PATH in bashrc ────────────────────
print_step "Updating PATH..."
if ! grep -q "SARAL_DIR" "$HOME/.bashrc" 2>/dev/null; then
    echo "" >> "$HOME/.bashrc"
    echo "# Saral Lang v1.0.0" >> "$HOME/.bashrc"
    echo "export SARAL_DIR=$SARAL_DIR" >> "$HOME/.bashrc"
    echo "# AI Provider Key (paste your key here after --setup-ai):" >> "$HOME/.bashrc"
    echo "# export SARAL_AI_KEY=your_api_key_here" >> "$HOME/.bashrc"
    print_ok "Added to .bashrc"
else
    print_ok "PATH already configured"
fi

# ── Step 7: Verify installation ──────────────────────
print_step "Verifying installation..."
if $PYTHON "$SARAL_DIR/saral.py" --version &>/dev/null; then
    print_ok "Saral Lang is working correctly"
else
    print_warn "Could not verify — try running: saral --version"
fi

# ── Done ─────────────────────────────────────────────
echo ""
echo "╔══════════════════════════════════════════════╗"
echo "║   ✅  Saral Lang installed successfully!     ║"
echo "╚══════════════════════════════════════════════╝"
echo ""
echo "   How to use Saral Lang:"
echo ""
echo "   1. Run a program:      saral myfile.saral"
echo "   2. Interactive mode:   saral --interactive"
echo "   3. AI writes code:     saral --generate"
echo "   4. Check your code:    saral --check myfile.saral"
echo "   5. Explain code:       saral --explain myfile.saral"
echo "   6. Show Python output: saral --show myfile.saral"
echo "   7. See version:        saral --version"
echo "   8. Setup AI provider:  saral --setup-ai"
echo "   9. Check AI status:    saral --status"
echo ""
echo "   Example files are in:  $SARAL_DIR/examples/"
echo ""
echo "   AI Setup:"
echo "   Run 'saral --setup-ai' and paste your API key"
echo "   Supports: OpenAI, DeepSeek, Gemini, Groq,"
echo "             Anthropic, Mistral, Cohere"
echo ""
echo "   Restart your terminal or run: source ~/.bashrc"
echo ""
echo "   GitHub: https://github.com/Asha-Arun/saral-lang"
echo "   SARAL LANG™ — Trademark Pending Class 42"
echo ""
